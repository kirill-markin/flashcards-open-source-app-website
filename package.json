{
  "name": "flashcards-open-source-app-website",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.18.0",
  "description": "Marketing website for Flashcards Open Source App",
  "author": "Kirill Markin",
  "license": "MIT",
  "scripts": {
    "generate:static-content": "tsx scripts/generateStaticContent.ts",
    "predev": "npm run generate:static-content",
    "prebuild": "npm run generate:static-content",
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint ."
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "gray-matter": "^4.0.3",
    "hast-util-sanitize": "^5.0.2",
    "mdast-util-to-hast": "^13.2.1",
    "next": "16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-html": "^16.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.6",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.5",
    "eslint-config-next": "16.2.10",
    "postcss": "^8.5.19",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "postcss": "$postcss"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true,
    "sharp@0.34.5": true,
    "unrs-resolver@1.12.2": true
  },
  "engines": {
    "node": "24.x"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kirill-markin/flashcards-open-source-app-website"
  }
